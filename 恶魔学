-- 长词优先排序
local sortedKeys = {}
for key, _ in pairs(Translations) do
    table.insert(sortedKeys, key)
end
table.sort(sortedKeys, function(a, b) return #a > #b end)

-- ==================== 翻译核心 ====================
local function translateText(text)
    if type(text) ~= "string" or text == "" then return text end
    local result = Translations[text]
    if result then return result end
    local trimmed = text:gsub("^%s+", ""):gsub("%s+$", "")
    if trimmed ~= text then
        result = Translations[trimmed]
        if result then return result end
    end
    local lowerText = text:lower()
    for en, cn in pairs(Translations) do
        if en:lower() == lowerText then return cn end
    end
    result = text
    local replaced = {}
    for _, en in ipairs(sortedKeys) do
        local alreadyReplaced = false
        for _, rep in ipairs(replaced) do
            if result:find(rep, 1, true) then
                alreadyReplaced = true
                break
            end
        end
        if not alreadyReplaced then
            local cn = Translations[en]
            local pattern = "(%W?)" .. en:gsub("%W", "%%%0") .. "(%W?)"
            local newResult, count = result:gsub(pattern, function(before, after)
                if before:match("%w") or after:match("%w") then
                    return before .. en .. after
                end
                return before .. cn .. after
            end)
            if count > 0 then
                result = newResult
                table.insert(replaced, en)
            end
        end
    end
    return result
end

-- ==================== 注入器（带节流） ====================
local TextX = {}
TextX.__index = TextX

-- 节流控制：UI大量涌现时暂停翻译
local throttleTimer = 0
local isThrottled = false
local pendingObjects = {}

function TextX:translateObject(obj)
    if not obj or type(obj.Text) ~= "string" then return end
    local original = obj.Text
    if original == "" then return end
    local translated = translateText(original)
    if translated ~= original then
        obj.Text = translated
        return true
    end
    return false
end

function TextX:scanContainer(parent)
    if not parent then return 0 end
    local count = 0
    for _, obj in ipairs(parent:GetDescendants()) do
        if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
            if self:translateObject(obj) then count = count + 1 end
        end
    end
    return count
end

-- 带节流的监听：大量UI爆发时延迟处理
function TextX:watchContainer(parent)
    if not parent then return end
    parent.DescendantAdded:Connect(function(obj)
        task.wait()
        if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
            -- 节流：延迟0.5秒处理，让UI先批量创建完
            local objRef = obj
            task.delay(0.3, function()
                if objRef and objRef.Parent then
                    self:translateObject(objRef)
                end
            end)
        end
    end)
end

function TextX:setupHook()
    local mt = getrawmetatable(game)
    if not mt then return false end
    local oldNewIndex = mt.__newindex
    if not oldNewIndex then return false end
    setreadonly(mt, false)
    mt.__newindex = newcclosure(function(t, k, v)
        if k == "Text" and type(v) == "string" then
            if t:IsA("TextLabel") or t:IsA("TextButton") or t:IsA("TextBox") then
                local translated = translateText(v)
                if translated ~= v then
                    return oldNewIndex(t, k, translated)
                end
            end
        end
        return oldNewIndex(t, k, v)
    end)
    setreadonly(mt, true)
    return true
end

function TextX:forceScan()
    local count = 0
    local function scan(parent)
        if not parent then return end
        for _, obj in ipairs(parent:GetDescendants()) do
            if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
                if self:translateObject(obj) then count = count + 1 end
            end
        end
    end
    scan(game:GetService("CoreGui"))
    local player = game.Players.LocalPlayer
    if player and player:FindFirstChild("PlayerGui") then
        scan(player.PlayerGui)
    end
    return count
end

