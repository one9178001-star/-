    TextX:scanContainer(playerGui)
    TextX:watchContainer(playerGui)
end

if player then
    player.ChildAdded:Connect(function(child)
        if child.Name == "PlayerGui" then
            task.wait(0.3)
            TextX:scanContainer(child)
            TextX:watchContainer(child)
        end
    end)
end

