local sortedKeys = {}
for key, _ in pairs(Translations) do
    table.insert(sortedKeys, key)
end
table.sort(sortedKeys, function(a, b) return #a > #b end)

local function translateText(text)
    if type(text) ~= "string" or text == "" then return text end
    if Translations[text] then return Translations[text] end
    local trimmed = text:gsub("^%s+", ""):gsub("%s+$", "")
    if Translations[trimmed] then return Translations[trimmed] end
    local lowerText = text:lower()
    for en, cn in pairs(Translations) do
        if en:lower() == lowerText then return cn end
    end
    local result = text
    local replaced = {}
    for _, en in ipairs(sortedKeys) do
        local alreadyReplaced = false
        for _, rep in ipairs(replaced) do
            if result:find(rep, 1, true) then
                alreadyReplaced = true
                break
            end
        end
        if not alreadyReplaced then
            local cn = Translations[en]
            local newResult = result:gsub(en, cn)
            if newResult ~= result then
                result = newResult
                table.insert(replaced, en)
            end
        end
    end
    return result
end

local function hookMetatable()
    local mt = getrawmetatable(game)
    if not mt then return false end
    local old = mt.__newindex
    if not old then return false end
    setreadonly(mt, false)
    mt.__newindex = newcclosure(function(t, k, v)
        if k == "Text" and type(v) == "string" then
            local isTextObject = t:IsA("TextLabel") or t:IsA("TextButton") or t:IsA("TextBox")
            if isTextObject then
                local translated = translateText(v)
                if translated ~= v then
                    return old(t, k, translated)
                end
            end
        end
        return old(t, k, v)
    end)
    setreadonly(mt, true)
    return true
end

local function scanOnce()
    local count = 0
    local function scan(parent)
        if not parent then return end
        for _, v in ipairs(parent:GetDescendants()) do
            local isTextObject = v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox")
            if isTextObject then
                pcall(function()
                    local original = v.Text
                    if original and original ~= "" then
                        local translated = translateText(original)
                        if translated ~= original then
                            v.Text = translated
                            count = count + 1
                        end
                    end
                end)
            end
        end
    end
    
    scan(game:GetService("CoreGui"))
    local player = game.Players.LocalPlayer
    if player then
        local pg = player:FindFirstChild("PlayerGui")
        if pg then scan(pg) end
        player.ChildAdded:Connect(function(child)
            if child.Name == "PlayerGui" then
                task.wait(0.3)
                scan(child)
                child.DescendantAdded:Connect(function(ui)
                    task.wait()
                    local isTextObject = ui:IsA("TextLabel") or ui:IsA("TextButton") or ui:IsA("TextBox")
                    if isTextObject and ui.Text and ui.Text ~= "" then
                        pcall(function()
                            local translated = translateText(ui.Text)
                            if translated ~= ui.Text then
                                ui.Text = translated
                            end
                        end)
                    end
                end)
            end
        end)
    end
    
    local coreGui = game:GetService("CoreGui")
    coreGui.DescendantAdded:Connect(function(ui)
        task.wait()
        local isTextObject = ui:IsA("TextLabel") or ui:IsA("TextButton") or ui:IsA("TextBox")
        if isTextObject and ui.Text and ui.Text ~= "" then
            pcall(function()
                local translated = translateText(ui.Text)
                if translated ~= ui.Text then
                    ui.Text = translated
                end
            end)
        end
    end)
    
    return count
end

task.wait(2)
hookMetatable()
local count = scanOnce()
